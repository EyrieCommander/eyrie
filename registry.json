      "install_method": "script",
      "install_cmd": "curl -fsSL https://github.com/sipeed/picoclaw/releases/latest/download/picoclaw_$(uname -s)_$(uname -m).tar.gz | tar xz -C ${HOME}/go/bin picoclaw && echo 'Installed picoclaw to ~/go/bin/picoclaw'",
      "requirements": ["go>=1.21"],
      "config_format": "json",
      "config_path": "~/.picoclaw/config.json",
