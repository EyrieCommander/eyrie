      "adapter_type": "hybrid",
      "default_port": 18790,
      "start_cmd": "picoclaw gateway",
      "stop_cmd": "",
      "status_cmd": "",
      "restart_cmd": "",
      "health_url": "http://localhost:18790/health",
      "log_dir": "~/.picoclaw/logs",
      "log_format": "json",
      "config_schema": {
        "common_fields": [
          {
            "key": "gateway.port",
            "label": "gateway port",
