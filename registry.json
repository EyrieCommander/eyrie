            "description": "port for the gateway health and channel servers",
            "min": 1024,
            "max": 65535
          },
          {
            "key": "gateway.host",
            "label": "gateway host",
            "type": "text",
            "default": "127.0.0.1",
            "required": true,
            "description": "host address for gateway to bind to"
          },
          {
            "key": "agents.defaults.provider",
            "label": "LLM provider",
            "type": "select",
            "options": ["anthropic", "openai", "openrouter", "ollama"],
            "default": "openrouter",
            "required": true,
            "description": "which LLM provider to use"
          },
          {
            "key": "agents.defaults.model_name",
            "label": "model",
            "type": "text",
            "default": "anthropic/claude-sonnet-4-20250514",
            "required": true,
            "description": "model identifier (provider/model format)"
          },
          {
            "key": "agents.defaults.restrict_to_workspace",
            "label": "restrict to workspace",
            "type": "checkbox",
            "default": true,
            "required": false,
            "description": "restrict file and shell access to the workspace directory"
          },
          {
            "key": "channels",
            "label": "enabled channels",
            "type": "multiselect",
            "options": ["telegram", "discord", "slack", "whatsapp", "weixin", "feishu", "dingtalk"],
